        },
        {
            "type": "Microsoft.Resources/deploymentScripts",
            "apiVersion": "2020-10-01",
            "name": "triggerFirstRun",
            "location": "[resourceGroup().location]",
            "kind": "AzureCLI",
            "identity": {
                "type": "UserAssigned",
                "userAssignedIdentities": {
                    "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('managedIdentityName'))]": {}
                }
            },
            "dependsOn": [
                "[resourceId('Microsoft.Web/sites', variables('functionAppName'))]",
                "[guid(resourceId('Microsoft.Web/sites', variables('functionAppName')), variables('managedIdentityName'), variables('WebsiteContributorRoleId'))]"
            ],
            "properties": {
                "azCliVersion": "2.50.0",
                "retentionInterval": "PT1H",
                "timeout": "PT5M",
                "scriptContent": "sleep 30 && az functionapp restart --name $FA_NAME --resource-group $RG_NAME && echo 'Function App restarted, run_on_startup will trigger first import'",
                "environmentVariables": [
                    {
                        "name": "FA_NAME",
                        "value": "[variables('functionAppName')]"
                    },
                    {
                        "name": "RG_NAME",
                        "value": "[resourceGroup().name]"
                    }
                ]
            }
        }
    ],
    "outputs": {
        "functionAppName": {
            "type": "string",
            "value": "[variables('functionAppName')]"
        },
        "storageAccountName": {
            "type": "string",
            "value": "[variables('storageAccountName')]"
        },
        "pollingSchedule": {
            "type": "string",
            "value": "[variables('pollingSchedule')]"
        },
        "auditTableName": {
            "type": "string",
            "value": "[if(parameters('EnableAuditLogging'), variables('AuditTableName'), 'N/A')]"
        },
        "workbookName": {
            "type": "string",
            "value": "[if(parameters('EnableAuditLogging'), 'SOCRadar TAXII 2.1 Dashboard', 'N/A')]"
        }
    }
}
